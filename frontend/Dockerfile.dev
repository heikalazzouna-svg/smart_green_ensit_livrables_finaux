FROM node:20-alpine

WORKDIR /app

# Copy dependency manifests first (cache layer)
COPY package.json ./

# Install dependencies — use legacy-peer-deps to handle any peer conflicts
RUN npm install --legacy-peer-deps

# Copy source files (volumes will override in dev, but this makes a self-contained image)
COPY . .

EXPOSE 3000

CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "3000"]
